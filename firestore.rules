rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admin kontrolü: ayarlar/config → adminEmails listesinde user.email var mı?
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/ayarlar/config)
        && request.auth.token.email in get(/databases/$(database)/documents/ayarlar/config).data.adminEmails;
    }

    // Projeler (teklif talepleri)
    match /projeler/{projeId} {
      // Herkes form gönderebilir (giriş gerekmez); zorunlu alanlar kontrol edilir
      allow create: if request.resource.data.keys().hasAll(['baslik', 'musteri_ad', 'musteri_email'])
        && request.resource.data.baslik is string && request.resource.data.baslik.size() > 0
        && request.resource.data.musteri_email is string && request.resource.data.musteri_email.size() > 3;
      // Admin tümünü, müşteri yalnızca kendi projesini okuyabilir
      allow read: if isAdmin()
        || (request.auth != null && resource.data.musteri_email == request.auth.token.email);
      // Admin tümünü güncelleyebilir, müşteri yalnızca kendi projesini
      allow update, delete: if isAdmin()
        || (request.auth != null && resource.data.musteri_email == request.auth.token.email);

      // Teklifler (sub-collection)
      match /teklifler/{teklifId} {
        // Admin veya projenin sahibi okuyabilir
        allow read: if isAdmin()
          || (request.auth != null
              && get(/databases/$(database)/documents/projeler/$(projeId)).data.musteri_email == request.auth.token.email);
        // Yalnızca admin yazabilir
        allow write: if isAdmin();
      }
    }

    // Müşteri profilleri
    match /musteriler/{uid} {
      // Kullanıcı kendi profilini oluşturabilir/güncelleyebilir
      allow create, update: if request.auth != null && request.auth.uid == uid;
      // Admin tümünü, müşteri yalnızca kendi profilini okuyabilir
      allow read: if isAdmin() || (request.auth != null && request.auth.uid == uid);
    }

    // Site ayarları (iletişim bilgileri vb.)
    match /ayarlar/{docId} {
      // Herkes okuyabilir (site ziyaretçileri iletişim bilgilerini görür)
      allow read: if true;
      // Admin yazabilir
      allow write: if isAdmin();
    }

    // İlk kurulum bootstrap: config yoksa giriş yapan kişi oluşturabilir
    match /ayarlar/config {
      allow read: if true;
      allow write: if isAdmin()
        || !exists(/databases/$(database)/documents/ayarlar/config);
    }
  }
}
